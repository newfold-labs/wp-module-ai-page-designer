{
    "name": "newfold-labs/wp-module-ai-page-designer",
    "description": "AI-powered page and post designer for WordPress with live preview and publishing capabilities",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Newfold Digital",
            "homepage": "https://newfold.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "NewfoldLabs\\WP\\Module\\AIPageDesigner\\": "includes"
        }
    },
    "require": {
        "php": ">=7.3",
        "newfold-labs/wp-module-loader": "^1.0",
        "newfold-labs/wp-module-data": "^2.0",
        "newfold-labs/wp-module-ai": "^1.3"
    },
    "scripts": {
        "lint": "vendor/bin/phpcs --standard=phpcs.xml .",
        "fix": "vendor/bin/phpcbf --standard=phpcs.xml .",
        "i18n-pot": "vendor/bin/wp i18n make-pot . ./languages/wp-module-ai-page-designer.pot --headers='{\"Report-Msgid-Bugs-To\":\"https://github.com/newfold-labs/wp-module-ai-page-designer/issues\",\"POT-Creation-Date\":\"2025-03-10T00:00:00+00:00\"}' --exclude=node_modules,build,tests",
        "i18n-po": "vendor/bin/wp i18n update-po ./languages/wp-module-ai-page-designer.pot ./languages",
        "i18n-mo": "vendor/bin/wp i18n make-mo ./languages"
    },
    "require-dev": {
        "newfold-labs/wp-php-standards": "^1.2.5",
        "roave/security-advisories": "dev-latest"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
